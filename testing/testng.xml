<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Magellan Response Test Suite" parallel="tests" thread-count="3" verbose="2">

    <!-- ==================== Listeners ==================== -->
    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <!-- ==================== API Tests (Cucumber + TestNG) ==================== -->
    <test name="API Tests - Cucumber">
        <parameter name="browser" value="CHROME"/>
        <parameter name="headless" value="true"/>
        <classes>
            <class name="api.testing.runners.CucumberTestNGRunner"/>
        </classes>
    </test>

    <!-- ==================== Selenium UI Tests ==================== -->
    <test name="UI Tests - Selenium">
        <parameter name="browser" value="CHROME"/>
        <parameter name="headless" value="true"/>
        <packages>
            <package name="api.testing.selenium"/>
        </packages>
    </test>

    <!-- ==================== Karate API Tests ==================== -->
    <test name="API Tests - Karate">
        <classes>
            <class name="api.testing.runners.KarateRunner"/>
        </classes>
    </test>

</suite>
